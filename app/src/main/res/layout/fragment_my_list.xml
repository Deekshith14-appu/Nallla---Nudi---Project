<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Saved entries list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp" />

    <!-- Empty state (Requirement 4.5) -->
    <LinearLayout
        android:id="@+id/layout_my_list_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_list_empty"
            android:textSize="16sp"
            android:textColor="@color/on_background"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_list_empty_kannada"
            android:textSize="15sp"
            android:textColor="@color/on_background"
            android:gravity="center" />

    </LinearLayout>

    <!-- Start Flashcards button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_flashcards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/start_flashcards"
        android:textSize="16sp"
        app:icon="@android:drawable/ic_media_play" />

</LinearLayout>
