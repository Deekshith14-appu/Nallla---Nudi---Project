<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Word of the Day Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_word_of_day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/wotd_card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/wotd_card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/word_of_the_day"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_wotd_term"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading…"
                    android:textColor="@color/on_background"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_wotd_translation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/secondary"
                    android:textSize="18sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tap_to_explore"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Browse by Subject label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/browse_by_subject"
            android:textColor="@color/on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Subject Filter Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_subjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_science"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subject_science"
                style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_mathematics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subject_mathematics"
                style="@style/Widget.MaterialComponents.Chip.Action" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_commerce"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subject_commerce"
                style="@style/Widget.MaterialComponents.Chip.Action" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Search Shortcut Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_search_shortcut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/search_hint"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_menu_search"
            app:iconGravity="start" />

    </LinearLayout>

</ScrollView>
